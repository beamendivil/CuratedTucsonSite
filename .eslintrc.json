{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "anime": "readonly",
    "Typed": "readonly",
    "Splitting": "readonly",
    "Splide": "readonly",
    "echarts": "readonly"
  },
  "overrides": [
    {
      "files": [
        "api/**/*.js",
        "playwright.config.js",
        "scripts/**/*.js",
        "src/**/*.js",
        "tailwind.config.js",
        "tests/**/*.js"
      ],
      "env": {
        "node": true
      }
    }
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  }
}
